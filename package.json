{
  "name": "dot-globe",
  "version": "1.0.4",
  "description": "Minimal 3D dot globe for React — NASA Black Marble night lights, city bloom pulses, customizable shaders",
  "keywords": [
    "globe",
    "3d",
    "react",
    "threejs",
    "three.js",
    "nasa",
    "night-lights",
    "webgl",
    "particles",
    "earth",
    "map",
    "visualization"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "unpkg": "dist/embed.global.js",
  "jsdelivr": "dist/embed.global.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react && tsup src/embed.ts --format iife --global-name DotGlobe --outDir dist --no-dts && tsup src/embed-min.ts --format iife --global-name DotGlobeMin --outDir dist --no-dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --external react --watch"
  },
  "dependencies": {
    "three": ">=0.150.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/three": "^0.160.0",
    "react": "^18",
    "tsup": "^8",
    "typescript": "^5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/krtbgb/dot-globe"
  },
  "homepage": "https://kurt.xyz/dot-globe",
  "bugs": {
    "url": "https://github.com/krtbgb/dot-globe/issues"
  }
}
